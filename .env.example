# Copy this file to .env and fill in your values. Never commit the real .env.

# GCP
GCP_PROJECT=your-shared-project-id
GCP_REGION=us-central1

# Models
GEN_MODEL=gemini-2.5-flash
JUDGE_MODEL=gemini-2.5-flash

# Embeddings
EMBED_DIM=768
EMBED_CONCURRENCY=15

# Retrieval
TOP_K=5

# Database (reached through the Cloud SQL Auth Proxy on localhost)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=YOURID_ragdb
DB_USER=postgres
DB_PASSWORD=set-a-strong-password

# Where the downloaded PDFs live
CORPUS_DIR=corpus

# Eval target
API_URL=http://localhost:8080/query
